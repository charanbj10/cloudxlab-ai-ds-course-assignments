   "source": [
    "def base2decimal(a) :\n",
    "    ans = 0\n",
    "    pow = 0\n",
    "\n",
    "    while(a > 0) :\n",
    "        rem = a % 10\n",
    "        ans += rem * (base ** pow)\n",
    "        pow += 1\n",
    "\n",
    "        a = a // 10\n",
    "    \n",
    "    print(ans)\n"
   ]
  },
